
@model List<Categories>

@{
    Layout="_DashboardLayout";
}



<div class="container mt-4">

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="bi bi-plus-circle-fill"></i> اضافة فئة جديدة 
            </h5>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
              @Html.AntiForgeryToken()

              <div class="mb-3">
                <label class="form-label">اسم الفئة</label>
                <input type="text" name="Name" placeholder="أدخل اسم الفئة" class="form-control" />
              </div>

               <div class="mb-3">
                <label class="form-label">الايقونة </label>
                <input type="text" name="Icon" placeholder="أدخل كود الأيقونة" class="form-control" />
              </div>

             

              <div class="mb-3">
               
               <button class="btn btn-success px-4 fw-bload">حفظ الفئة</button>
               <a asp-action="Index" class="btn btn-light">إلغاء وعودة</a>
                
              </div>
            </form>
        </div>
    </div>

   

</div>
 <div class="card mt-5">
        <div class="card-body">
            <table class="table">
             <thead>
                  <tr>
                    <td>#</td>
                    <td>اسم الفئة</td>
                    <td>أيقونة الفئة </td>
                    <td colspan="2">اجراء</td>
                  </tr>
             </thead>

             <tbody>
              @if(Model==null )
              {
                <tr>
                    <td>لا توجد بيانات</td>
                </tr>
              }

              else{
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bload text-secandory">@item.Id</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Name</td>
                          <td class="text-success">
                                        <i class="@($"{item.Icon} fs-1")"></i>
                          </td>
                         <td> <a href="#"><i class="bi bi-pencil-square text-success"></i></a></td>
                        <td> <a href="#"><i class="bi bi-trash3 text-danger"></i></a></td>
                    </tr>
                }
              }
             </tbody>
            </table>
        </div>
    </div>