@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
    @* حقن المترجم إذا أردت ترجمة الكلمات الثابتة لاحقاً *@
@inject IViewLocalizer Localizer

@{
    // التحقق مما إذا كانت اللغة الحالية تُكتب من اليمين لليسار (مثل العربية)
    var isRTL = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRTL ? "rtl" : "ltr";
    var htmlLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
   
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["المتجر الإليكتروني"] - المتجر الإليكتروني</title>
    <script type="importmap"></script>
      @if (isRTL)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mini_store.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <link href='https://fonts.googleapis.com/css?family=Cairo' rel='stylesheet'>
<style>
body {
    font-family: 'Cairo';font-size: 22px;
}
.custom-footer{
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;

    background-color: #000;
    color: #fff;

    padding: 8px 0;
    font-size: 14px;
    text-align: center;
}

.custom-footer a{
    color: #fff;
    text-decoration: none;
}

  .main-content {
            @(isRTL ? "margin-right: 250px;" : "margin-left: 250px;")
            min-height: 100vh;
        }
</style>
</head>
<body  lang="@htmlLang" dir="@htmlDir">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3" style="background-color: rgb(74, 16, 132);">
            <div class="container-fluid">
                <a class="navbar-brand text-white" asp-area="" asp-controller="Home" asp-action="Index">  @SharedLocalizer["Store"]  </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between ">
                    <ul class="navbar-nav flex-grow-1 text-white">
                        <li class="nav-item">
                            <a class="nav-link text-white " asp-area="" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy">من نحن</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy"> اتصل بنا   </a>
                        </li>
                    </ul>
                </div>

                  <div class="d-flex justify-content-between align-items-center">
                
                <h4>@ViewData["Title"]</h4>

                <div class="d-flex align-items-center gap-3">
                    
                    <partial name="_SelectLanguage" />

                    <div class="vr text-muted" style="height: 20px;"></div>

                    <span class="badge bg-primary p-2 fs-6 fw-normal">
                        <i class="bi bi-person-circle"></i>
                        م. سعد
                    </span>

                </div>

            </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   <footer class="custom-footer">
    <div class="container text-center">
        &copy; 2026 - mini_store -
        <a asp-area=""
           asp-controller="Home"
           asp-action="Privacy">
            Privacy
        </a>
    </div>
</footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
