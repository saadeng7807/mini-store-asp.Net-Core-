@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
    @* حقن المترجم إذا أردت ترجمة الكلمات الثابتة لاحقاً *@
@inject IViewLocalizer Localizer

@{
    // التحقق مما إذا كانت اللغة الحالية تُكتب من اليمين لليسار (مثل العربية)
    var isRTL = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRTL ? "rtl" : "ltr";
    var htmlLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
   
}
<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - لوحة التحكم</title>

    @if (isRTL)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f8f9fa;
            overflow-x: hidden;
        }

        /* القائمة الجانبية متجاوبة مع الاتجاه */
        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            @(isRTL ? "right: 0;" : "left: 0;") /* سحر الاتجاهات هنا */
            background: #1e293b;
        }

        .sidebar .nav-link {
            color: #cbd5e1;
            padding: 12px 20px;
            margin: 5px 10px;
            border-radius: 8px;
        }

        .sidebar .nav-link:hover {
            background: #334155;
            color: white;
        }

        /* المحتوى الرئيسي متجاوب مع الاتجاه */
        .main-content {
            @(isRTL ? "margin-right: 250px;" : "margin-left: 250px;")
            min-height: 100vh;
        }
    </style>
</head>

<body>

    <aside class="sidebar">
        <div class="text-center p-4 border-bottom">
            <h4 class="text-white">
                <i class="bi bi-shop"></i>
                 @SharedLocalizer["StoreSystem"]
            </h4>
            <small class="text-secondary">
                لوحة التحكم 
            </small>
        </div>

         <ul class="nav flex-column mt-3">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house"></i>
                    @SharedLocalizer["Home"]
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-controller="Categories" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    @SharedLocalizer["Categories"]
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-controller="Products" asp-action="Index">
                    <i class="bi bi-box-seam"></i>
                    @SharedLocalizer["Products"]
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link">
                    <i class="bi bi-graph-up"></i>
                    @SharedLocalizer["Reports"]
                </a>
            </li>

            <li class="nav-item mt-3">
                <a class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    @SharedLocalizer["Logout"]
                </a>
            </li>

             <li class="nav-item mt-3">
                <a class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    @SharedLocalizer["ReportUsers"]
                </a>
            </li>
        </ul>
    </aside>

    <div class="main-content d-flex flex-column">

        <header class="bg-white shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                
                <h4>@ViewData["Title"]</h4>

                <div class="d-flex align-items-center gap-3">
                    
                    <partial name="_SelectLanguage" />

                    <div class="vr text-muted" style="height: 20px;"></div>

                    <span class="badge bg-primary p-2 fs-6 fw-normal">
                        <i class="bi bi-person-circle"></i>
                        م. سعد
                    </span>

                </div>

            </div>
        </header>

        <main class="p-4 flex-grow-1">
            @RenderBody()
        </main>

        <footer class="bg-white text-center p-3 border-top">
            <small>
                © 2026 نظام إدارة المتجر - لأغراض تعليمية
            </small>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>