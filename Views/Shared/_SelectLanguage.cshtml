@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Options

@* حقن الخيارات لمعرفة اللغات المتاحة في النظام *@
@inject IViewLocalizer Localizer
@inject IOptions<RequestLocalizationOptions> LocOptions

@{
    // جلب ثقافة المستخدم الحالية
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    
    // تجهيز قائمة اللغات المتاحة (ar, en-US)
    var cultureItems = LocOptions.Value.SupportedUICultures
        .Select(c => new SelectListItem { Value = c.Name, Text = c.NativeName })
        .ToList();
        
    // تحديد مسار الصفحة الحالية لإرجاع المستخدم إليها بعد تغيير اللغة
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" : $"~{Context.Request.Path.Value}";
}

<div title="@Localizer["Request culture provider:"] @requestCulture?.Provider?.GetType().Name">
    <form id="selectLanguage" asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@returnUrl" method="post" class="form-horizontal" role="form">
        <div class="d-flex align-items-center">
            <i class="bi bi-globe me-2"></i> <select name="culture"
                    onchange="this.form.submit();"
                    asp-for="@requestCulture.RequestCulture.UICulture.Name" 
                    asp-items="cultureItems" 
                    class="form-select form-select-sm">
            </select>
        </div>
    </form>
</div>