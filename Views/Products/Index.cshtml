
@model List<Product>

@{
     Layout="_DashboardLayout";
}
 
<div class="container mt-4">

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="bi bi-plus-circle-fill"></i> اضافة منتج جديد
            </h5>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
              @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">اختر الفئة</label>
                    <select class="form-select" name="CategoryId">
                      @foreach(var item in ViewBag.categories)
                      {
                        <option value="@item.Id">
                            @item.Name
                        </option>
                      }
                    </select>
                </div>
              <div class="mb-3">
                <label class="form-label">اسم المنتج</label>
                <input type="text" name="Name" placeholder="أدخل اسم المنتج" class="form-control" />
              </div>

               <div class="mb-3">
                <label class="form-label">سعر المنتج</label>
                <input type="number" name="Price" placeholder="أدخل سعر المنتج" class="form-control" />
              </div>

               <div class="mb-3">
                <label class="form-label">صورة المنتج</label>
                <input type="text" name="Images" placeholder="أدخل صورة المنتج" class="form-control" />
              </div>

              <div class="mb-3">
               
               <button class="btn btn-success px-4 fw-bload">حفظ المنتج</button>
               <a asp-action="Index" class="btn btn-light">إلغاء وعودة</a>
                
              </div>
            </form>
        </div>
    </div>

   

</div>
 <div class="card mt-5">
        <div class="card-body">
            <table class="table">
             <thead>
                  <tr>
                    <td>#</td>
                    <td>اسم المنتج</td>
                    <td>سعر المنتج</td>
                    <td>الفئة</td>
                    <td colspan="2">اجراء</td>
                  </tr>
             </thead>

             <tbody>
              @if(Model==null )
              {
                <tr>
                    <td>لا توجد بيانات</td>
                </tr>
              }

              else{
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bload text-secandory">@item.Id</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Name</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Price</td>
                         <td class="ps-4 fw-bload text-secandory">@item.Categories.Name</td>
                        <td> <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square text-success"></i></a></td>
                        <td> <a  asp-action="Delete"  asp-route-id="@item.Id" onclick="return confirm('هل انت متأكد من الحذف')"><i class="bi bi-trash3 text-danger"></i></a></td>
                    </tr>
                }
              }
             </tbody>
            </table>
        </div>
    </div>