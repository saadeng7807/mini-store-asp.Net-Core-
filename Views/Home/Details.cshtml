@using Microsoft.AspNetCore.Http.Features
@{

}

<div class="container">
    <div class="row">
        <div class="col-sm-4">
            <div class="card h-100">
                <img src="~/images/@ViewBag.Products.Image" class="card-img-top" width="100" height="300" />
                <div class="card-body">
                    <h4>
                        @ViewBag.Products.Name
                    </h4>

                      <small class="text-muted">
                        @ViewBag.Products.Description
                     </small>
                     <hr>
                       <small class="text-text badge bg-danger">
                        @ViewBag.Products.Price ريال
                     </small>
                     <hr>
                         <a asp-action=""  class="btn btn-danger p-1">  اضف الى السلة</a>
                         <a asp-action=""  class="btn btn-success p-1">   العودة الى التسوق    </a>
                </div>
            </div>
        </div>
    </div>
</div>